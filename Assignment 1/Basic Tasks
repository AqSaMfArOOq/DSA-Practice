/* ---------------------- Q2: Bubble Sort -------------------------
Q2.A.1
Bubble sort compares two nearby elements and swaps them if they are in wrong order. After each pass the largest element moves to the end like a bubble

Q2.A.2
Best: O(n)
Average: O(n^2)
Worst: O(n^2)
If already sorted with flag, it stops early.

Q2.A.3
Selection sort uses fewer swaps, while bubble sort is simpler and works well when the list is almost sorted
*/

void bubbleSort(int arr[], int n, int &swapCount){
    for(int i=0;i<n-1;i++){
        bool swapped = false;
        for(int j=0;j<n-i-1;j++){
            if(arr[j]>arr[j+1]){
                swap(arr[j],arr[j+1]);
                swapCount++;
                swapped = true;
            }
        }
        cout<<"After pass "<<i+1<<": ";
        for(int k=0;k<n;k++) cout<<arr[k]<<" ";
        cout<<endl;
        if(!swapped) break;
    }
}

/* ------------------- Q3: Binary Search ----------------------
Q3.A.1
In Binary search, Array must be sorted in ascending to descending order otherwise it will not give binary search.

Q3.A.2
Dry run:
low=0 high=7 mid=3
value=12 < 23 so low=4
low=4 high=7 mid=5
value=23 found

Q3.A.3
Binary search O(log n) is faster than linear O(n) Because it reduces search space by half each time.
*/


int binarySearch(int arr[], int n, int key, int &iterations){
    int low = 0, high = n - 1;
    while(low <= high){
        iterations++;
        int mid = (low + high) / 2;
        if(arr[mid] == key){
            return mid;
        }
        else if(arr[mid] < key){
            low = mid + 1;
        }
        else{
            high = mid - 1;
        }
    }
    return -1;
}

